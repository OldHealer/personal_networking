# Copy to .env and fill in real values. .env is gitignored.
# All SECRET_* / *_PASSWORD / *_SECRET values MUST be unique per environment.

# --- Prod DB (rockfile app) ---
DATABASE__DB_USER=rockfile
DATABASE__DB_PASSWORD=<choose-a-strong-password>
DATABASE__DB_NAME=rockfile_db
# DATABASE__DB_HOST / DATABASE__DB_PORT are wired in docker-compose; override only for local-dev against an external DB.

# --- Keycloak admin bootstrap ---
KEYCLOAK_ADMIN=owner
KEYCLOAK_ADMIN_PASSWORD=<choose-a-strong-password>

# --- Keycloak DB (rockfile-keycloak-db container) ---
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<choose-a-strong-password>
KEYCLOAK_DB_NAME=keycloak

# --- Keycloak client (set only if the client is confidential) ---
KEYCLOAK__CLIENT_SECRET=

# --- Keycloak admin client (used by the app to create users) ---
KEYCLOAK_ADMIN__CLIENT_ID=rockfile-admin-cli
KEYCLOAK_ADMIN__CLIENT_SECRET=<paste-client-secret-from-keycloak>

# --- Token signing for the app ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
TOKEN__SECRET_KEY=<generate-at-least-48-random-chars>

# --- Local dev mode (loads .env.local instead of .env) ---
# LOCAL_DEV=true
